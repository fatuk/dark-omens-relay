{
  "name": "dark-omens-relay",
  "version": "0.1.0",
  "description": "Relay / matchmaking server for Dark Omens",
  "scripts": {
    "dev": "tsx watch src/relay/server.ts",
    "dev:nodemon": "nodemon --watch src --ext ts --exec \"tsx src/relay/server.ts\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:unified": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:api": "tsx src/api/server.ts",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "resend": "^6.11.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
